Revert changes to cxa_thread_atexit.cpp introduced by:

       [libc++] Enable -Wmissing-prototypes
       https://github.com/llvm/llvm-project/pull/116261

These changes break building `__cxa_thread_atexit` for Solaris, which
does not have a native cxa_thread_atexit_impl.


--- llvm-project-22.1.0.src/libcxxabi/src/cxa_thread_atexit.cpp.~1~	2026-02-24 07:35:28.000000000 +0000
+++ llvm-project-22.1.0.src/libcxxabi/src/cxa_thread_atexit.cpp	2026-03-05 19:10:43.912162731 +0000
@@ -21,6 +21,9 @@
 
   using Dtor = void(*)(void*);
 
+  extern "C" _LIBCXXABI_FUNC_VIS
+  int __cxa_thread_atexit(Dtor, void*, void*) throw();
+
   extern "C"
 #ifndef HAVE___CXA_THREAD_ATEXIT_IMPL
   // A weak symbol is used to detect this function's presence in the C library
@@ -106,7 +109,6 @@
 
 #endif // HAVE___CXA_THREAD_ATEXIT_IMPL
 
-#if defined(__linux__) || defined(__Fuchsia__)
 extern "C" {
 
   _LIBCXXABI_FUNC_VIS int __cxa_thread_atexit(Dtor dtor, void* obj, void* dso_symbol) throw() {
@@ -142,5 +144,4 @@
 #endif // HAVE___CXA_THREAD_ATEXIT_IMPL
   }
 } // extern "C"
-#endif // defined(__linux__) || defined(__Fuchsia__)
 } // namespace __cxxabiv1
